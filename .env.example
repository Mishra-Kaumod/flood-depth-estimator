# .env.example
# FloodWatch AI — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=development        # development | staging | production
LOG_LEVEL=INFO

# ── Database ──────────────────────────────────────────────────────────────────
FLOODWATCH_DB_URL=postgresql://floodwatch:floodwatch@localhost:5432/floodwatch

# ── Redis (job queue — required for reliability) ──────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── API Security ──────────────────────────────────────────────────────────────
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
FLOODWATCH_API_KEY=replace_with_strong_random_key
# Set to false only in local development
# API_KEY_REQUIRED=true

# ── Gemini AI (optional — enables ensemble validation) ────────────────────────
GEMINI_API_KEY=                # leave blank to disable Gemini ensemble
# GEMINI_ENABLED=true

# ── Pipeline model weights (paths to .pth / .pt files) ────────────────────────
# SEGFORMER_WEIGHTS=models/segformer_water.pth
# YOLO_WEIGHTS=models/yolov8n.pt
# DEPTH_WEIGHTS=models/depth_anything_v2_vitl.pth
# SEVERITY_WEIGHTS=models/severity_xgboost.pkl

# ── Alerts (optional — fires on HIGH RISK or CRITICAL) ────────────────────────
# ALERT_ENABLED=true
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
# ALERT_MIN_RISK=HIGH RISK

# Twilio SMS (optional)
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_FROM_NUMBER=+1415xxxxxxx
# ALERT_SMS_NUMBERS=+919876543210,+919876543211

# ── Observability ─────────────────────────────────────────────────────────────
# SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXX
# METRICS_ENABLED=true
# METRICS_PORT=9090
